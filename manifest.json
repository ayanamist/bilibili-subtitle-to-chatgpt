{
  "manifest_version": 3,
  "name": "Bilibili Subtitle to AI",
  "version": "3.8.0",
  "description": "提取 B 站字幕或音频并发送到AI进行总结",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://api.bilibili.com/*",
    "https://aisubtitle.hdslb.com/*",
    "https://aistudio.google.com/*",
    "https://*.bilivideo.com/*",
    "https://*.bilivideo.cn/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*"
      ],
      "js": [
        "bilibili-content-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.bilibili.com/video/*"
      ],
      "js": [
        "bilibili-content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "chatgpt-content.js"
      ]
    },
    {
      "matches": [
        "https://aistudio.google.com/*"
      ],
      "js": [
        "aistudio-content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["prompt_chatgpt.txt", "prompt_aistudio.txt"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://aistudio.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
